rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ✅ ตัวละคร: เจ้าของและ admin ลบได้
    match /characters/{charId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         resource.data.userId == request.auth.uid || 
         isAdmin(request.auth.token.email));
    }
    
    // ✅ Session: เจ้าของและ admin ลบได้
    match /sessions/{sessId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         (exists(/databases/$(database)/documents/characters/$(resource.data.characterId)) &&
          (get(/databases/$(database)/documents/characters/$(resource.data.characterId)).data.userId == request.auth.uid ||
           isAdmin(request.auth.token.email))));
    }
    
    // ✅ Gold: เจ้าของและ admin ลบได้
    match /gold/{goldId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         (exists(/databases/$(database)/documents/characters/$(resource.data.characterId)) &&
          (get(/databases/$(database)/documents/characters/$(resource.data.characterId)).data.userId == request.auth.uid ||
           isAdmin(request.auth.token.email))));
    }
    
    // ✅ Favor: เจ้าของและ admin ลบได้
    match /favor/{favorId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         (exists(/databases/$(database)/documents/characters/$(resource.data.characterId)) &&
          (get(/databases/$(database)/documents/characters/$(resource.data.characterId)).data.userId == request.auth.uid ||
           isAdmin(request.auth.token.email))));
    }
    
    // ✅ DM Logs: เจ้าของและ admin ลบได้
    match /dm_logs/{logId} {
      allow read, write: if request.auth != null && 
        (resource == null || 
         (exists(/databases/$(database)/documents/characters/$(resource.data.characterId)) &&
          (get(/databases/$(database)/documents/characters/$(resource.data.characterId)).data.userId == request.auth.uid ||
           isAdmin(request.auth.token.email))));
    }
    
    // ✅ Settings
    match /settings/{doc} {
      allow read: if true;
      allow write: if false;
    }
    
    // 🔒 ฟังก์ชันตรวจสอบ admin
    function isAdmin(email) {
      return email != null && 
        exists(/databases/$(database)/documents/settings/admin) &&
        email in get(/databases/$(database)/documents/settings/admin).data.adminEmails;
    }
  }
}